{
  "extends": "@tsjam/tsconfig-bases/tsconfig.node.json",
  "compilerOptions": {
    "module": "NodeNext",
    "target": "ES2024",
    "moduleResolution": "nodenext",
    "allowJs": true,
    /* Paths */
    "rootDir": ".",
    "outDir": "lib",
    "paths": {
      "*": ["*", "src/*"]
    }
  },
  "exclude": ["lib/*", "packages/*", "node_modules/**"]
}
